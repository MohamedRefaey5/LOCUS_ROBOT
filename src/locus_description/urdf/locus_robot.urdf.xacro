<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="locus_robot">

  <!-- =========================================================
       ROBOT DIMENSIONS
       chassis: 50cm long, 30cm wide, 10cm tall
       wheels:  6cm radius, 4cm wide, 50g each
       caster:  2.5cm radius sphere at front
       total mass: ~1.1kg
       ========================================================= -->

  <xacro:property name="chassis_length" value="0.50"/>
  <xacro:property name="chassis_width"  value="0.30"/>
  <xacro:property name="chassis_height" value="0.10"/>
  <xacro:property name="chassis_mass"   value="1.0"/>

  <xacro:property name="wheel_radius"   value="0.05"/>
  <xacro:property name="wheel_width"    value="0.04"/>
  <xacro:property name="wheel_mass"     value="0.05"/>

  <!-- track_width = distance between left and right wheel centers -->
  <xacro:property name="track_width"    value="0.30"/>

  <!-- caster radius slightly less than wheel so robot sits level -->
  <xacro:property name="caster_radius"  value="0.05"/>
  <xacro:property name="caster_mass"    value="0.025"/>

  <!-- =========================================================
       INERTIA MACROS
       ========================================================= -->

  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${(m/12)*(h*h + d*d)}" ixy="0" ixz="0"
        iyy="${(m/12)*(w*w + d*d)}" iyz="0"
        izz="${(m/12)*(w*w + h*h)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${(m/12)*(3*r*r + h*h)}" ixy="0" ixz="0"
        iyy="${(m/12)*(3*r*r + h*h)}" iyz="0"
        izz="${(m/2)*r*r}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${(2/5)*m*r*r}" ixy="0" ixz="0"
        iyy="${(2/5)*m*r*r}" iyz="0"
        izz="${(2/5)*m*r*r}"/>
    </inertial>
  </xacro:macro>

  <!-- =========================================================
       MATERIALS
       ========================================================= -->

  <material name="blue">  <color rgba="0.1 0.4 0.8 1"/></material>
  <material name="black"> <color rgba="0.0 0.0 0.0 1"/></material>
  <material name="grey">  <color rgba="0.5 0.5 0.5 1"/></material>
  <material name="white"> <color rgba="0.9 0.9 0.9 1"/></material>

  <!-- =========================================================
       BASE FOOTPRINT
       ========================================================= -->

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- =========================================================
       BASE LINK
       ========================================================= -->

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia
      m="${chassis_mass}"
      w="${chassis_width}"
      h="${chassis_height}"
      d="${chassis_length}"/>
  </link>

  <!-- =========================================================
       LEFT DRIVE WHEEL
       ========================================================= -->

  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia
      m="${wheel_mass}"
      r="${wheel_radius}"
      h="${wheel_width}"/>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel"/>
    <origin xyz="-0.10 ${track_width/2} ${-wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="1.0" velocity="10.0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- =========================================================
       RIGHT DRIVE WHEEL
       ========================================================= -->

  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia
      m="${wheel_mass}"
      r="${wheel_radius}"
      h="${wheel_width}"/>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel"/>
    <origin xyz="-0.10 ${-track_width/2} ${-wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="1.0" velocity="10.0"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- =========================================================
       CASTER WHEEL — front passive sphere
       Using a sphere is the standard Gazebo approach for casters.
       A sphere has uniform contact in all directions so it
       slides freely without resisting the robot's rotation.
       ========================================================= -->

  <link name="caster_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <xacro:sphere_inertia m="${caster_mass}" r="${caster_radius}"/>
  </link>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_wheel"/>
    <!-- front of chassis, dropped so sphere touches ground -->
    <origin xyz="0.18 0 ${-caster_radius}" rpy="0 0 0"/>
  </joint>

  <!-- =========================================================
       LIDAR LINK
       ========================================================= -->

  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <!-- no collision block — prevents lidar from hitting itself -->
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0.05 0 ${chassis_height + 0.02}" rpy="0 0 0"/>
  </joint>

  <!-- =========================================================
       IMU LINK
       ========================================================= -->

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.01"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <!-- no collision block -->
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
  </joint>

  <!-- =========================================================
       ROS2 CONTROL — only 2 drive wheels
       ========================================================= -->

  <ros2_control name="locus_robot" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>

    <joint name="right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>

  </ros2_control>

  <xacro:include filename="$(find locus_description)/urdf/locus_gazebo.xacro"/>

</robot>
