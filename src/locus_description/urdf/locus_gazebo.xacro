<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <gazebo>
    <!-- gz_ros2_control: publishes odom TF and joint states via controllers -->
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find locus_description)/config/locus_controllers.yaml</parameters>
      <ros>
        <remapping>~/robot_description:=/robot_description</remapping>
      </ros>
    </plugin>

    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <plugin filename="gz-sim-imu-system"
            name="gz::sim::systems::Imu">
    </plugin>

  </gazebo>

  <!-- LiDAR sensor -->
  <gazebo reference="lidar_link">
    <sensor name="gpu_lidar" type="gpu_lidar">
      <update_rate>10</update_rate>
      <topic>scan</topic>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <visualize>true</visualize>
      <frame_id>lidar_link</frame_id>
    </sensor>
  </gazebo>

  <!-- IMU sensor -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>imu</topic>
      <frame_id>imu_link</frame_id>
    </sensor>
  </gazebo>

  <!-- Wheel friction with torsional = 0 -->
  <gazebo reference="front_left_wheel">
    <collision>
      <surface>
        <friction>
          <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
          <torsional>
            <coefficient>0.0</coefficient>
            <use_patch_radius>false</use_patch_radius>
            <patch_radius>0.0</patch_radius>
          </torsional>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference="front_right_wheel">
    <collision>
      <surface>
        <friction>
          <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
          <torsional>
            <coefficient>0.0</coefficient>
            <use_patch_radius>false</use_patch_radius>
            <patch_radius>0.0</patch_radius>
          </torsional>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference="rear_left_wheel">
    <collision>
      <surface>
        <friction>
          <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
          <torsional>
            <coefficient>0.0</coefficient>
            <use_patch_radius>false</use_patch_radius>
            <patch_radius>0.0</patch_radius>
          </torsional>
        </friction>
      </surface>
    </collision>
  </gazebo>

  <gazebo reference="rear_right_wheel">
    <collision>
      <surface>
        <friction>
          <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
          <torsional>
            <coefficient>0.0</coefficient>
            <use_patch_radius>false</use_patch_radius>
            <patch_radius>0.0</patch_radius>
          </torsional>
        </friction>
      </surface>
    </collision>
  </gazebo>

</robot>
