"base_link" -> "rear_left_wheel_joint" [label="xyz: -0.3 0.25 -0.06 \nrpy: 0 -0 0"]
"rear_left_wheel_joint" -> "rear_left_wheel"
"base_link" -> "rear_right_wheel_joint" [label="xyz: -0.3 -0.25 -0.06 \nrpy: 0 -0 0"]
