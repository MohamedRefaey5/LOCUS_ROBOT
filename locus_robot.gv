"base_link" -> "front_right_wheel_joint" [label="xyz: 0.3 -0.25 -0.06 \nrpy: 0 -0 0"]
"front_right_wheel_joint" -> "front_right_wheel"
"base_link" -> "imu_joint" [label="xyz: 0 0 0.15 \nrpy: 0 -0 0"]
